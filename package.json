{
  "name": "expenditure-tracker-backend",
  "version": "1.0.0",
  "description": "Expenditure Tracker Backend",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "vitest",
    "test:integration": "vitest run src/test/integration/suites/",
    "test:integration:watch": "vitest src/test/integration/suites/",
    "clear-db": "npx wrangler d1 migrations apply expenditure --local",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate"
  },
  "keywords": [],
  "author": "Houchuan Dong",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "axios": "^1.14.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "vitest-mock-extended": "^3.1.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@libsql/client": "^0.17.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.8",
    "http-status-codes": "^2.3.0",
    "jose": "^6.2.2",
    "zod": "^3.23.8"
  }
}
