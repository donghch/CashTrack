{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"], 
      "enabled": false
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
      "enabled": true
    }
  },
  "agent": {
  },
  "plugin": ["context-mode"]
}