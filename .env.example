# Environment variables for Expenditure Tracker Backend
# Copy this file to .env and fill in the values

# Database configuration
# SQLite database file path (libsql format)
DB_FILE_NAME=file:data/data.db

# Test configuration
# Base URL for integration tests
TEST_BASE_URL=http://localhost:3000

# Authentication
# Password for single-user authentication
PASSWORD=your_secure_password_here

# JWT secret key for signing tokens
# Generate a secure random string (e.g., 32+ characters)
JWT_SECRET=your_jwt_secret_key_here